{
  "name": "@tacky-org/config",
  "version": "0.0.5",
  "description": "Config management",
  "repository": {
    "url": "https://github.com/tacky-org/Config"
  },
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "require": "./build/index.js",
      "import": "./build/index.js"
    }
  },
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow@1.2.2 pnpm",
    "prettify": "pnpm exec prettier --write src/.",
    "dev": "pnpm install && pnpm exec storybook dev -p 6006 --debug",
    "build-github": "pnpm run prettify && pnpm run test && pnpm exec tsc --noEmit && pnpm run build",
    "build": "pnpm run prettify && pnpm run test && pnpm exec tsup && pnpm exec storybook build",
    "release:patch": "pnpm install && pnpm run build && pnpm version patch --git-tag-version=false",
    "release:minor": "pnpm install && pnpm run build && pnpm version minor --git-tag-version=false",
    "release:major": "pnpm install && pnpm run build && pnpm version major --git-tag-version=false",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-a11y": "10.2.10",
    "@storybook/addon-docs": "10.2.10",
    "@storybook/addon-onboarding": "10.2.10",
    "@storybook/builder-vite": "10.2.10",
    "@storybook/react-vite": "10.2.10",
    "@tanstack/react-query": "^5.101.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.3.6",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  }
}

{
  "name": "@gertvdb/foo",
  "version": "0.1.0",
  "description": "Template for all libraries powered by React",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "require": "./build/index.js",
      "import": "./build/index.js"
    }
  },
  "type": "module",
  "scripts": {
    "prettify": "pnpm exec prettier --write src/.",
    "start": "pnpm exec storybook dev -p 6006 --debug",
    "storybook": "pnpm exec storybook dev -p 6006",
    "build-github": "pnpm run prettify && pnpm run test && pnpm exec tsc --noEmit && pnpm run build",
    "build": "pnpm run prettify && pnpm run test && pnpm exec tsup && pnpm exec storybook build",
    "release:patch": "pnpm run build && pnpm version patch --git-tag-version=false",
    "release:minor": "pnpm run build && pnpm version minor --git-tag-version=false",
    "release:major": "pnpm run build && pnpm version major --git-tag-version=false",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "ts-node": "^10.9.2",

    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@types/react": "^19.0.12",
    "@types/node": "^22.13.14",

    "storybook": "^10.2.10",
    "@storybook/react-vite": "10.2.10",
    "@storybook/builder-vite": "10.2.10",
    "@storybook/addon-docs": "10.2.10",
    "@storybook/addon-a11y": "10.2.10",
    "@storybook/addon-onboarding": "10.2.10",
    "@chromatic-com/storybook": "^5.0.1",

    "vite": "^6.2.3",
    "@vitejs/plugin-react-swc": "^3.8.1",

    "jest": "^29.7.0",
    "ts-jest": "^29.3.0",
    "@types/jest": "^29.5.14",

    "prettier": "^3.5.3"
  }
}
